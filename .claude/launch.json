{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Harmony Server",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "cd /tmp/harmony && python3 server.py"],
      "port": 1223
    },
    {
      "name": "Admin Client",
      "runtimeExecutable": "python",
      "runtimeArgs": ["client.py"],
      "port": 0
    },
    {
      "name": "Agent Client",
      "runtimeExecutable": "python",
      "runtimeArgs": ["client.py"],
      "port": 1222
    },
    {
      "name": "harmony-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "-d", "site"],
      "port": 8080
    }
  ]
}
